# =============================================================================
# vault-observer/.env.example — Operator Dashboard Configuration
# =============================================================================
# Copy to vault-observer/.env and fill in values.
# This file is generated automatically by Ansible (04-app-stack.yml) during
# a normal deploy. You only need to fill this manually for local development.
# =============================================================================

# Vault address — use the container service name when running inside Docker/nerdctl
# Use http://127.0.0.1:8200 if running the dashboard directly on the host (not in container)
VAULT_ADDR=http://vault-enterprise:8200

# Root Vault token — used for read-only identity API queries (entity/group listing).
# Get the current token: cat ~/.demo/vault/.vault-token
VAULT_TOKEN=

# Full Vault namespace path including the admin/ parent prefix.
# Get from Terraform: cd terraform && terraform output vault_namespace
# Example: admin/agentic-iam-20vo
VAULT_NAMESPACE=

# Log level for the Streamlit app (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
