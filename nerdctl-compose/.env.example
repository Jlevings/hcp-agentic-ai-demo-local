# =============================================================================
# .env.example — Environment Variables Template
# =============================================================================
# Copy this file to nerdctl-compose/.env and fill in ALL values before
# running the demo.
#
#   cp nerdctl-compose/.env.example nerdctl-compose/.env
#
# Also copy terraform/terraform.tfvars.example → terraform/terraform.tfvars
# and fill in the same values there (Terraform reads from tfvars, deploy.sh
# reads from this .env file to set the Ansible environment).
#
# SECURITY: This file contains secrets — never commit it to version control.
# It is listed in .gitignore.
#
# See docs/ENTRA-ID-SETUP.md for how to obtain all Azure values.
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# Microsoft Entra ID — Required
# See: docs/ENTRA-ID-SETUP.md
# ─────────────────────────────────────────────────────────────────────────────

# Your Azure tenant ID (Azure Portal > Entra ID > Overview > Tenant ID)
TENANT_ID=

# products-web app registration (Azure Portal > App registrations)
WEB_CLIENT_ID=
WEB_CLIENT_SECRET=

# products-agent app registration
AGENT_CLIENT_ID=
AGENT_CLIENT_SECRET=

# products-mcp app registration
MCP_CLIENT_ID=

# Security group Object IDs (Azure Portal > Entra ID > Groups > [group] > Object ID)
READONLY_GROUP_OBJECT_ID=   # db-readonly group (Alice is a member)
READWRITE_GROUP_OBJECT_ID=  # db-readwrite group (Bob is a member)

# OAuth scopes (space-separated — MUST be quoted to avoid shell parsing errors)
# WEB_SCOPES: OIDC scopes + agent API delegated permission
# Example: WEB_SCOPES="openid profile email api://YOUR_AGENT_CLIENT_ID/access"
WEB_SCOPES="openid profile email api://YOUR_AGENT_CLIENT_ID/access"

# AGENT_SCOPES: The MCP API scope used in OBO token exchange
# Example: AGENT_SCOPES="api://YOUR_MCP_CLIENT_ID/access"
AGENT_SCOPES="api://YOUR_MCP_CLIENT_ID/access"

# Redirect URI — must match exactly in Entra ID app registration
REDIRECT_URI=http://localhost:8501/callback

# ─────────────────────────────────────────────────────────────────────────────
# Demo User Credentials
# ─────────────────────────────────────────────────────────────────────────────

# Alice — read-only user (member of db-readonly group)
ALICE_USERNAME=    # e.g. alice@yourtenant.onmicrosoft.com
ALICE_PASSWORD=

# Bob — read-write user (member of db-readwrite group)
BOB_USERNAME=      # e.g. bob@yourtenant.onmicrosoft.com
BOB_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# LLM Backend — Choose ONE option
# ─────────────────────────────────────────────────────────────────────────────

# ── Option A: AWS Bedrock (primary) ──
# Requires AWS credentials with Bedrock enabled in us-west-2.
# Get the profile ARN from: AWS Console > Bedrock > Inference profiles
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=       # Only needed for temporary credentials (e.g., SSO)
AWS_DEFAULT_REGION=us-west-2
BEDROCK_INFERENCE_PROFILE_ARN=
# Example ARN: arn:aws:bedrock:us-west-2::foundation-model/anthropic.claude-sonnet-4-5-20250929-v1:0

# ── Option B: Anthropic API (alternative) ──
# Get your key from: https://console.anthropic.com/account/keys
# Leave BEDROCK_INFERENCE_PROFILE_ARN empty and set this instead.
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Local Infrastructure (auto-set by Ansible/Terraform — update after deploy)
# ─────────────────────────────────────────────────────────────────────────────

# Vault root token — populated by 02-vault.yml
# Run: VAULT_TOKEN=$(cat ~/.demo/vault/.vault-token)
VAULT_TOKEN=

# Vault namespace — populated by terraform apply
# Run: VAULT_NAMESPACE=$(cd terraform && terraform output -raw vault_namespace)
VAULT_NAMESPACE=

# MongoDB admin credentials — set by 03-mongodb.yml
# Run: MONGO_PASSWORD=$(cat ~/.demo/mongodb/password)
MONGO_USERNAME=mongoadmin
MONGO_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# Container Image Settings
# ─────────────────────────────────────────────────────────────────────────────

# Image tag — use 'latest' or pin to a specific version
tag=latest

# Platform — use linux/amd64 for Intel Mac or linux/arm64 for Apple Silicon
# Rancher Desktop on Apple Silicon handles x86 emulation automatically.
platform=linux/amd64
