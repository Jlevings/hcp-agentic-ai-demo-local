# =============================================================================
# products-agent .env — Generated by Ansible (do not edit manually)
# =============================================================================
# The products-agent is the AI-powered backend API. It:
#   1. Validates incoming JWTs from the web frontend
#   2. Performs the On-Behalf-Of (OBO) token exchange with Entra ID
#   3. Calls the MCP server to execute product operations
#   4. Uses AWS Bedrock (or Anthropic API) to process user messages
# =============================================================================

# ── JWT Validation ─────────────────────────────────────────────────────────
# The JWKS URI is used to fetch Entra ID's public keys for token verification.
JWKS_URI=https://login.windows.net/common/discovery/keys

# The issuer claim in Entra ID tokens — must match exactly.
JWT_ISSUER=https://login.microsoftonline.com/{{ tenant_id }}/v2.0

# The audience the agent validates — the agent's own client ID.
JWT_AUDIENCE={{ agent_client_id }}

# ── Microsoft Entra ID — On-Behalf-Of (OBO) Token Exchange ─────────────────
# These credentials allow the agent to exchange the user's access token
# for an OBO token that represents the user's delegated identity.
ENTRA_CLIENT_ID={{ agent_client_id }}
ENTRA_CLIENT_SECRET={{ agent_client_secret }}
ENTRA_SCOPE={{ agent_scopes }}
ENTRA_TOKEN_URL=https://login.microsoftonline.com/{{ tenant_id }}/oauth2/v2.0/token

# ── LLM Backend ─────────────────────────────────────────────────────────────
{% if bedrock_inference_profile_arn is defined and bedrock_inference_profile_arn != "" %}
# Option A: AWS Bedrock (primary)
BEDROCK_INFERENCE_PROFILE_ARN={{ bedrock_inference_profile_arn }}
BEDROCK_REGION={{ bedrock_region | default('us-west-2') }}
{% else %}
# Option B: Anthropic API directly
ANTHROPIC_API_KEY={{ anthropic_api_key | default('') }}
{% endif %}

# ── MCP Server Connection ────────────────────────────────────────────────────
# The agent connects to the MCP server over the Docker network (by service name).
PRODUCTS_MCP_SERVER_URL=http://products-mcp:8000/mcp

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
