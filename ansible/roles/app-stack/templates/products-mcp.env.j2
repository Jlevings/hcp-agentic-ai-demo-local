# =============================================================================
# products-mcp .env — Generated by Ansible (do not edit manually)
# =============================================================================
# The products-mcp (Model Context Protocol server) is the security boundary
# between the agent and MongoDB. It:
#   1. Validates OBO tokens via Vault's JWT auth backend
#   2. Requests short-lived MongoDB credentials from Vault
#   3. Executes database operations with those credentials
#   4. Credentials expire automatically — no long-lived secrets held here
# =============================================================================

# ── MongoDB Connection ───────────────────────────────────────────────────────
# host.docker.internal resolves to the host machine's IP from inside a container.
# This allows the MCP container to reach MongoDB running on the host (port 27017).
DB_HOST=host.docker.internal
DB_PORT=27017
DB_NAME=test
COLLECTION_NAME=products

# ── MCP Server Settings ──────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_NAME=products-mcp
MAX_RESULTS=100

# ── JWT Validation (for incoming requests from the agent) ────────────────────
JWKS_URI=https://login.windows.net/common/discovery/keys
JWT_ISSUER=https://login.microsoftonline.com/{{ tenant_id }}/v2.0
JWT_AUDIENCE={{ mcp_client_id }}

# ── Vault Connection ─────────────────────────────────────────────────────────
# host.docker.internal allows the MCP container to reach Vault on the host.
VAULT_ADDR=http://host.docker.internal:8200

# Fully-qualified Vault namespace (e.g., admin/agentic-iam-abc123).
# Populated from Terraform output: terraform output -raw vault_namespace
VAULT_NAMESPACE={{ vault_namespace }}

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
