# =============================================================================
# products-web .env — Generated by Ansible (do not edit manually)
# =============================================================================
# The products-web is a Streamlit web application that provides:
#   1. Microsoft Entra ID OIDC login (OAuth2 authorization code flow)
#   2. A chat interface where users type natural language commands
#   3. Forwarding of requests (with JWT) to the products-agent
# =============================================================================

# ── Microsoft Entra ID OIDC Configuration ────────────────────────────────────
TENANT_ID={{ tenant_id }}
CLIENT_ID={{ web_client_id }}
CLIENT_SECRET={{ web_client_secret }}

# Scopes requested at login — includes OpenID standard scopes plus the
# delegated permission to call the agent API.
SCOPE={{ web_scopes }}

# Redirect URI — must exactly match what's registered in Entra ID.
# For local dev this is http://localhost:8501/callback.
REDIRECT_URI={{ redirect_uri }}

# Entra ID base URL (standard — do not change)
BASE_URL=https://login.microsoftonline.com

# ── Agent Backend ─────────────────────────────────────────────────────────────
# The web app forwards user chat messages to the products-agent.
# Uses Docker service name for container-to-container communication.
PRODUCTS_AGENT_URL=http://products-agent:8001

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
